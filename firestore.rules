rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    function isVerified() {
      return isSignedIn();
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isAdmin() {
      return isVerified() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isValidPrompt(p) {
      return p.title is string && p.title.size() <= 60 &&
             p.description is string && p.description.size() <= 300 &&
             p.content is string && p.content.size() <= 10000 &&
             (p.authorId == request.auth.uid || p.authorId == 'system') &&
             p.authorName is string &&
             p.scene in ['SRT', 'Custom'] &&
             p.usageCount is number &&
             p.favoriteCount is number &&
             p.isPublic is bool &&
             p.isOfficial is bool &&
             p.createdAt == request.time &&
             p.updatedAt == request.time;
    }

    match /prompts/{promptId} {
      allow get: if existing().isPublic == true || (existing().isOfficial == true) || (isSignedIn() && existing().authorId == request.auth.uid) || isAdmin();
      allow list: if (resource.data.isPublic == true) || (resource.data.isOfficial == true) || (isSignedIn() && resource.data.authorId == request.auth.uid) || isAdmin();
      
      allow create: if isVerified() && isValidId(promptId) && isValidPrompt(incoming());
      
      allow update: if isSignedIn() && isValidId(promptId) && (
        (existing().authorId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'content', 'scene', 'isPublic', 'updatedAt']) &&
         incoming().title.size() <= 60 && incoming().description.size() <= 300 && incoming().updatedAt == request.time) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['usageCount', 'favoriteCount', 'updatedAt']) && incoming().updatedAt == request.time) ||
        isAdmin()
      );
      
      allow delete: if isSignedIn() && (existing().authorId == request.auth.uid || existing().authorId == 'system' || isAdmin());
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email']) &&
                    (incoming().isAdmin == existing().isAdmin || !incoming().keys().contains('isAdmin'));
      
      match /favorites/{favoriteId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
